{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yominelectric.com" }],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.yominelectric.com" },
        { "type": "header", "key": "x-forwarded-proto", "value": "http" }
      ],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yominelectric.com" }, { "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/about.html", "destination": "/about", "statusCode": 301 },
    { "source": "/contact.html", "destination": "/contact", "statusCode": 301 },
      { "source": "/products.html", "destination": "/products", "statusCode": 301 },
      { "source": "/product.html", "destination": "/products", "statusCode": 301 },
      { "source": "/product-details.html", "destination": "/product-details", "statusCode": 301 },
      { "source": "/process.html", "destination": "/process", "statusCode": 301 },
      { "source": "/solutions.html", "destination": "/solutions", "statusCode": 301 },
      { "source": "/video/company-overview.html", "destination": "/video/company-overview", "statusCode": 301 },
      { "source": "/energy-meter.html", "destination": "/products?category=energy-meter", "statusCode": 301 },
      { "source": "/voltage-stabilizer-regulator.html", "destination": "/products?category=voltage-stabilizer-regulator", "statusCode": 301 },
      { "source": "/current-transformer.html", "destination": "/products?category=current-transformer", "statusCode": 301 },
      { "source": "/variac-transformer.html", "destination": "/products?category=variac-transformer", "statusCode": 301 },
      { "source": "/screw-machine.html", "destination": "/products?category=screw-machine", "statusCode": 301 },
      { "source": "/fuse-protection.html", "destination": "/products?category=fuse-protection", "statusCode": 301 },
      { "source": "/voltage-protector.html", "destination": "/products?category=voltage-protector", "statusCode": 301 },
      { "source": "/socket-wiring.html", "destination": "/products?category=socket-wiring", "statusCode": 301 },
      { "source": "/terminal-connector.html", "destination": "/products?category=terminal-connector", "statusCode": 301 },
      { "source": "/solar-pv-products.html", "destination": "/products?category=solar-pv-products", "statusCode": 301 },
      { "source": "/tools-hardware.html", "destination": "/products?category=tools-hardware", "statusCode": 301 },
      { "source": "/security-seal.html", "destination": "/products?category=security-seal", "statusCode": 301 },
      { "source": "/other.html", "destination": "/products?category=other", "statusCode": 301 },
      { "source": "/yominelectric-main/:path*", "destination": "/", "statusCode": 301 }
  ],
  "routes": [
    { "src": "/wap/(.*)", "status": 410 },
    { "src": "/wap/(.*)\\.asp", "status": 410 },
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/products", "dest": "/products.html" },
    { "src": "/product.html", "dest": "/products.html" },
    { "src": "/product-details", "dest": "/product-details.html" },
    { "src": "/process", "dest": "/process.html" },
    { "src": "/solutions", "dest": "/solutions.html" },
    { "src": "/video/company-overview", "dest": "/video/company-overview.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
