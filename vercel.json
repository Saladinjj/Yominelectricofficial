{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yominelectric.com" }],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.yominelectric.com" },
        { "type": "header", "key": "x-forwarded-proto", "value": "http" }
      ],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yominelectric.com" }, { "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/about.html", "destination": "/about", "statusCode": 301 },
    { "source": "/contact.html", "destination": "/contact", "statusCode": 301 },
    { "source": "/products.html", "destination": "/products", "statusCode": 301 },
    { "source": "/product.html", "destination": "/products", "statusCode": 301 },
    { "source": "/product-details.html", "destination": "/product-details", "statusCode": 301 },
    { "source": "/process.html", "destination": "/process", "statusCode": 301 },
    { "source": "/solutions.html", "destination": "/solutions", "statusCode": 301 },
    { "source": "/video/company-overview.html", "destination": "/video/company-overview", "statusCode": 301 },
    { "source": "/yominelectric-main/:path*", "destination": "/", "statusCode": 301 }
  ],
  "routes": [
    { "src": "/wap/(.*)", "status": 410 },
    { "src": "/wap/(.*)\\.asp", "status": 410 },
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/products", "dest": "/products.html" },
    { "src": "/product.html", "dest": "/products.html" },
    { "src": "/product-details", "dest": "/product-details.html" },
    { "src": "/process", "dest": "/process.html" },
    { "src": "/solutions", "dest": "/solutions.html" },
    { "src": "/video/company-overview", "dest": "/video/company-overview.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
