{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "yominelectric.com" }],
      "destination": "https://www.yominelectric.com/:path*",
      "statusCode": 301
    },
    {
      "source": "/yominelectric-main/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Energy Meter"}],
      "destination": "/products?category=energy-meter",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Energy+Meter"}],
      "destination": "/products?category=energy-meter",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Voltage Stabilizer/Regulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Voltage+Stabilizer%2FRegulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Current Transformer"}],
      "destination": "/products?category=current-transformer",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Current+Transformer"}],
      "destination": "/products?category=current-transformer",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Variac/Transformer"}],
      "destination": "/products?category=variac-transformer",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Fuse & Protection"}],
      "destination": "/products?category=fuse-protection",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Voltage Protector"}],
      "destination": "/products?category=voltage-protector",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Socket & Wiring"}],
      "destination": "/products?category=socket-wiring",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Terminal & Connector"}],
      "destination": "/products?category=terminal-connector",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Solar/PV Products"}],
      "destination": "/products?category=solar-pv-products",
      "statusCode": 301
    },
    {
      "source": "/products",
      "has": [{"type": "query", "key": "cat", "value": "Tools & Hardware"}],
      "destination": "/products?category=tools-hardware",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "category", "value": "energy-meter"}],
      "destination": "/products?category=energy-meter",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "category", "value": "voltage-stabilizer-regulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Energy Meter"}],
      "destination": "/products?category=energy-meter",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Energy+Meter"}],
      "destination": "/products?category=energy-meter",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Voltage Stabilizer/Regulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Voltage+Stabilizer%2FRegulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Voltage+Stabilizer/Regulator"}],
      "destination": "/products?category=voltage-stabilizer-regulator",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Current Transformer"}],
      "destination": "/products?category=current-transformer",
      "statusCode": 301
    },
    {
      "source": "/products.html",
      "has": [{"type": "query", "key": "cat", "value": "Current+Transformer"}],
      "destination": "/products?category=current-transformer",
      "statusCode": 301
    }
  ],
  "routes": [
    { "src": "/wap/(.*)", "status": 410 },
    { "src": "/wap/(.*)\\.asp", "status": 410 },
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/products", "dest": "/products.html" },
    { "src": "/product.html", "dest": "/products.html" },
    { "src": "/product-details", "dest": "/product-details.html" },
    { "src": "/process", "dest": "/process.html" },
    { "src": "/solutions", "dest": "/solutions.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/video/company-overview", "dest": "/video/company-overview.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
